# Sandbox0 Managed Agents gateway.
SANDBOX0_API_KEY=s0_...
# MANAGED_AGENTS_BASE_URL=https://agents.sandbox0.ai

# Anthropic-compatible LLM provider stored in a Sandbox0 LLM vault.
MANAGED_AGENTS_LLM_API_KEY=provider-token
MANAGED_AGENTS_LLM_BASE_URL=https://api.z.ai/api/anthropic
MANAGED_AGENTS_MODEL=glm-5.1

# Optional: reuse existing resources instead of creating new ones on startup.
# MANAGED_AGENTS_AGENT_ID=agent_...
# MANAGED_AGENTS_ENVIRONMENT_ID=env_...
# MANAGED_AGENTS_VAULT_ID=vlt_...

# Optional: attach a hard TTL metadata value understood by Sandbox0 Managed Agents.
# MANAGED_AGENTS_HARD_TTL_SECONDS=3600

# Optional: print low-level status and model usage events.
# MANAGED_AGENTS_VERBOSE=1
