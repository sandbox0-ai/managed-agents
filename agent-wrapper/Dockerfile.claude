FROM ubuntu:22.04

ARG DEBIAN_FRONTEND=noninteractive
ARG GRADLE_VERSION=8.7
ARG GO_VERSION=1.22.12
ARG NODE_MAJOR=20
ARG CODEX_NPM_VERSION=latest
ARG RUBY_VERSION=3.3.10
ARG RUST_VERSION=1.77.2
ARG TARGETARCH=amd64
ARG UBUNTU_MIRROR=http://azure.archive.ubuntu.com/ubuntu
ARG UBUNTU_SECURITY_MIRROR=http://azure.archive.ubuntu.com/ubuntu

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ENV LANG=C.UTF-8 \
	LC_ALL=C.UTF-8 \
	CARGO_HOME=/usr/local/cargo \
	RUSTUP_HOME=/usr/local/rustup \
	PATH=/usr/local/go/bin:/usr/local/cargo/bin:/opt/gradle/bin:${PATH} \
	AGENT_WRAPPER_DEFAULT_VENDOR=claude \
	NODE_EXTRA_CA_CERTS=/var/run/sandbox0/netd/mitm-ca.crt

RUN sed -i \
		-e "s|http://archive.ubuntu.com/ubuntu|${UBUNTU_MIRROR}|g" \
		-e "s|http://security.ubuntu.com/ubuntu|${UBUNTU_SECURITY_MIRROR}|g" \
		/etc/apt/sources.list \
	&& printf '%s\n' \
		'Acquire::Retries "5";' \
		'Acquire::http::Timeout "30";' \
		'Acquire::https::Timeout "30";' \
		> /etc/apt/apt.conf.d/80-retries \
	&& apt-get update \
	&& apt-get install -y --no-install-recommends \
		apt-transport-https \
		ca-certificates \
		curl \
		dirmngr \
		gnupg \
		lsb-release \
		software-properties-common \
		wget \
	&& add-apt-repository -y ppa:deadsnakes/ppa \
	&& add-apt-repository -y ppa:ondrej/php \
	&& add-apt-repository -y ppa:ubuntu-toolchain-r/test \
	&& install -d -m 0755 /etc/apt/keyrings \
	&& curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
	&& echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" > /etc/apt/sources.list.d/nodesource.list \
	&& curl -fsSL https://packages.adoptium.net/artifactory/api/gpg/key/public | gpg --dearmor -o /etc/apt/keyrings/adoptium.gpg \
	&& echo "deb [signed-by=/etc/apt/keyrings/adoptium.gpg] https://packages.adoptium.net/artifactory/deb $(. /etc/os-release && echo "${VERSION_CODENAME}") main" > /etc/apt/sources.list.d/adoptium.list \
	&& apt-get update \
	&& apt-get install -y --no-install-recommends \
		build-essential \
		cmake \
		diffutils \
		docker.io \
		g++-13 \
		gawk \
		gcc-13 \
		git \
		grep \
		htop \
		libffi-dev \
		libgdbm-dev \
		libgmp-dev \
		libncurses-dev \
		libreadline-dev \
		libssl-dev \
		libyaml-dev \
		jq \
		make \
		maven \
		nano \
		nodejs \
		openssh-client \
		patch \
		php8.3-cli \
		php8.3-curl \
		php8.3-dev \
		php8.3-mbstring \
		php8.3-xml \
		pkg-config \
		postgresql-client \
		python3.12 \
		python3.12-dev \
		python3.12-venv \
		redis-tools \
		ripgrep \
		screen \
		sed \
		sqlite3 \
		tar \
		temurin-21-jdk \
		tmux \
		tree \
		unzip \
		vim \
		zlib1g-dev \
		zip \
	&& update-alternatives --install /usr/bin/gcc gcc /usr/bin/gcc-13 100 \
	&& update-alternatives --install /usr/bin/g++ g++ /usr/bin/g++-13 100 \
	&& curl -fsSL https://bootstrap.pypa.io/get-pip.py -o /tmp/get-pip.py \
	&& python3.12 /tmp/get-pip.py \
	&& ln -sf /usr/bin/python3.12 /usr/local/bin/python \
	&& ln -sf /usr/bin/python3.12 /usr/local/bin/python3 \
	&& ln -sf /usr/local/bin/pip3.12 /usr/local/bin/pip \
	&& ln -sf /usr/local/bin/pip3.12 /usr/local/bin/pip3 \
	&& curl -fsSL https://getcomposer.org/installer -o /tmp/composer-setup.php \
	&& php8.3 /tmp/composer-setup.php --install-dir=/usr/local/bin --filename=composer \
	&& curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local/bin sh \
	&& npm install --global yarn pnpm "@openai/codex@${CODEX_NPM_VERSION}" \
	&& curl -fsSL "https://cache.ruby-lang.org/pub/ruby/${RUBY_VERSION%.*}/ruby-${RUBY_VERSION}.tar.gz" -o /tmp/ruby.tgz \
	&& mkdir -p /tmp/ruby-src \
	&& tar -xzf /tmp/ruby.tgz -C /tmp/ruby-src --strip-components=1 \
	&& cd /tmp/ruby-src \
	&& ./configure --disable-install-doc \
	&& make -j"$(nproc)" \
	&& make install \
	&& gem update --system --no-document \
	&& gem install bundler --no-document \
	&& cd / \
	&& case "${TARGETARCH}" in \
		amd64) go_arch=amd64 ;; \
		arm64) go_arch=arm64 ;; \
		*) echo "unsupported TARGETARCH=${TARGETARCH}" >&2; exit 1 ;; \
	esac \
	&& curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${go_arch}.tar.gz" -o /tmp/go.tgz \
	&& rm -rf /usr/local/go \
	&& tar -C /usr/local -xzf /tmp/go.tgz \
	&& curl -fsSL https://sh.rustup.rs | sh -s -- -y --no-modify-path --profile minimal --default-toolchain "${RUST_VERSION}" \
	&& chmod -R a+rx /usr/local/cargo /usr/local/rustup \
	&& curl -fsSL "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip" -o /tmp/gradle.zip \
	&& unzip -q /tmp/gradle.zip -d /opt/gradle \
	&& ln -sf "/opt/gradle/gradle-${GRADLE_VERSION}/bin/gradle" /usr/local/bin/gradle \
	&& rm -rf /var/lib/apt/lists/* /tmp/* /root/.cache /root/.npm

WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm ci --omit=dev
COPY src ./src

EXPOSE 8080
CMD ["node", "src/index.js"]
