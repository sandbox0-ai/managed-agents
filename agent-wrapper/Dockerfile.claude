FROM node:22-bookworm-slim

RUN apt-get update \
	&& apt-get install -y --no-install-recommends \
		ca-certificates \
		curl \
		git \
		build-essential \
		pkg-config \
		python3 \
		python3-pip \
		python3-venv \
		python3-dev \
		ruby-full \
		ruby-dev \
		golang-go \
		cargo \
	&& update-ca-certificates \
	&& rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install --omit=dev
COPY src ./src

ENV AGENT_WRAPPER_DEFAULT_VENDOR=claude
ENV NODE_EXTRA_CA_CERTS=/var/run/sandbox0/netd/mitm-ca.crt
EXPOSE 8080
CMD ["node", "src/index.js"]
